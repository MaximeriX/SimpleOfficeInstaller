{
  "name": "SimpleOfficeInstaller",
  "version": "1.1.0",
  "main": "index.js",
  "private": true,
  "homepage": "https://maximerix.dev/soi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaximeriX/SimpleOfficeInstaller.git"
  },
  "bugs": {
    "url": "https://github.com/MaximeriX/SimpleOfficeInstaller/issues"
  },
  "funding": "https://maximerix.dev/donate",
  "devDependencies": {
    "clean-css": "^5.3.3",
    "electron": "^34.5.8",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "html-minifier-terser": "^7.2.0",
    "svgo": "^4.0.1",
    "terser": "^5.48.0"
  },
  "scripts": {
    "start": "electron .",
    "build": "npm run minify && electron-builder --win --ia32 --projectDir build",
    "minify": "node scripts/build.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "build": {
    "appId": "dev.maximerix.SimpleOfficeInstaller",
    "productName": "Simple Office Installer",
    "electronLanguages": ["en"],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["ia32"]
        }
      ],
      "icon": "icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "legalTrademarks": "Simple Office Installer",
      "fileDescription": "Simple Office Installer"
    },
    "portable": {
      "splashImage": "assets/splash.bmp"
    },
    "files": [
      "build/**/*"
    ],
    "asar": true,
    "compression": "normal",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true
    }
  },
  "keywords": [
    "office",
    "office365",
    "microsoft-office",
    "office-installer",
    "odt",
    "office-deployment-tool",
    "electron",
    "windows"
  ],
  "author": {
    "name": "MaximeriX",
    "url": "https://maximerix.dev"
  },
  "license": "MIT",
  "description": "A Microsoft Office installer for Office 365, 2024, 2021, 2019, and 2016."
}
